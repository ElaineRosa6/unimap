{
  "manifest_version": 3,
  "name": "Unimap Screenshot Bridge",
  "version": "0.2.0",
  "description": "Browser extension bridge for screenshot task execution and structured data collection from cyber space search engines.",
  "action": {
    "default_title": "Unimap Screenshot Bridge",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "src/background.js",
    "type": "module"
  },
  "permissions": [
    "tabs",
    "tabCapture",
    "scripting",
    "storage",
    "activeTab"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
